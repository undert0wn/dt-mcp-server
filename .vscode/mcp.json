        "DT_ENVIRONMENT": "https://[YOURTENANTID].sprint.apps.dynatracelabs.com"
      }
    },
    "demo.live": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@dynatrace-oss/dynatrace-mcp-server@latest",
        "--stdio"
      ],
      "env": {
        "DT_ENVIRONMENT": "https://guu84124.apps.dynatrace.com"
      }
    }
  }
}
